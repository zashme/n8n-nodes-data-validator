{
  "name": "n8n-nodes-data-validator",
  "version": "1.1.0",
  "description": "n8n community node to validate input data against a JSON Schema (ajv)",
  "keywords": [
    "n8n-community-node-package",
    "n8n",
    "validation",
    "json-schema",
    "ajv",
    "data-validation"
  ],
  "license": "MIT",
  "homepage": "https://github.com/zashme/n8n-nodes-data-validator",
  "author": {
    "name": "Alexandru Fiodorov",
    "email": "zashme@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/zashme/n8n-nodes-data-validator.git"
  },
  "engines": {
    "node": ">=18.10"
  },
  "main": "dist/nodes/DataValidator/DataValidator.node.js",
  "scripts": {
    "build": "rimraf dist && tsc && gulp build:icons",
    "build:watch": "tsc --watch",
    "dev": "n8n-node dev",
    "lint": "n8n-node lint",
    "lint:fix": "n8n-node lint --fix",
    "release": "n8n-node release",
    "prepublishOnly": "n8n-node prerelease"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "strict": true,
    "credentials": [],
    "nodes": [
      "dist/nodes/DataValidator/DataValidator.node.js"
    ]
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  },
  "dependencies": {
    "ajv": "^8.17.0",
    "ajv-errors": "^3.0.0",
    "ajv-formats": "^3.0.1"
  },
  "devDependencies": {
    "@n8n/node-cli": "*",
    "@types/normalize-package-data": "^2.4.4",
    "@typescript-eslint/parser": "^7.15.0",
    "eslint": "^8.56.0",
    "eslint-plugin-n8n-nodes-base": "^1.16.1",
    "gulp": "^4.0.2",
    "prettier": "^3.3.2",
    "rimraf": "^5.0.10",
    "release-it": "^19.0.4",
    "typescript": "^5.5.3"
  }
}
